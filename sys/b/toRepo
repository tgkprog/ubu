#!/usr/bin/env bash
if [ "$1" = "/?" ]; then echo "toRepo - Sync /b to repository directory"; exit 0; fi
if [ "$1" = "/help" ]; then
  echo "toRepo - Directory synchronization utility"
  echo ""
  echo "Usage: toRepo"
  echo ""
  echo "Syncs contents of /b to ~/code/gt/tgk/ubu/sys/b."
  echo "Uses rsync with --update to preserve newer files."
  echo "Excludes .git directories from sync."
  exit 0
fi

set -euo pipefail

SRC_DIR="/b"
DEST_DIR="/home/ubuntu/code/gt/tgk/ubu/sys/b"

if [ ! -d "$DEST_DIR" ]; then
  echo "Destination $DEST_DIR does not exist" >&2
  exit 1
fi

rsync -a --update --exclude='/.git/' --exclude='*/.git/' "$SRC_DIR"/ "$DEST_DIR"/
