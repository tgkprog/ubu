#!/bin/bash
if [ "$1" = "/?" ]; then echo "dns - Enable local dnsmasq DNS server"; exit 0; fi
if [ "$1" = "/help" ]; then
  echo "dns - DNS configuration switcher"
  echo ""
  echo "Usage: dns"
  echo ""
  echo "Disables systemd-resolved and enables dnsmasq."
  echo "Sets nameserver to 127.0.0.1 for local DNS."
  echo "Tests configuration with dig and ping."
  echo "Requires sudo privileges."
  exit 0
fi

echo "Enabling local dnsmasq DNS..."

sudo systemctl stop systemd-resolved
sudo systemctl disable systemd-resolved

sudo systemctl enable dnsmasq
sudo systemctl restart dnsmasq

sudo rm -f /etc/resolv.conf
echo "nameserver 127.0.0.1" | tee /etc/resolv.conf

dig reachme2.com @127.0.0.1
ping -c 2 sel2in.com

